---
import { education } from "../data";
---

<section id="education" class="py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 reveal">Education</h2>
    <div class="reveal border-l-4 border-accent pl-6">
      <h3 class="text-xl font-semibold">{education.school}</h3>
      <p class="text-accent font-medium">{education.degree}</p>
      <p class="text-sm text-gray-400 mb-3">{education.honors}</p>
      <div>
        <p class="text-sm font-medium text-gray-700 mb-2">Relevant Coursework</p>
        <div class="flex flex-wrap gap-2">
          {education.courses.map((course) => (
            <span class="text-sm text-gray-600 bg-gray-100 px-3 py-1 rounded-full">
              {course}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
