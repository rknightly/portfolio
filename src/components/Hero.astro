---
import { hero } from "../data";
---

<section id="hero" class="min-h-screen flex items-center justify-center pt-16">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <p class="text-indigo-600 font-medium mb-4 animate-fade-in-up">
      Hi, my name is
    </p>
    <h1 class="text-5xl md:text-6xl font-bold mb-4 animate-fade-in-up">
      {hero.name}
    </h1>
    <p class="text-xl md:text-2xl text-gray-500 mb-8 animate-fade-in-up-delay">
      {hero.tagline}
    </p>
    <a
      href="#about"
      class="inline-block border-2 border-indigo-600 text-indigo-600 px-8 py-3 rounded-lg hover:bg-indigo-600 hover:text-white transition-colors animate-fade-in-up-delay"
    >
      Learn more
    </a>
  </div>
</section>
