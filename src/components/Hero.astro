---
import { hero, social, socialIcons } from "../data";
---

<section id="hero" class="min-h-screen flex items-center justify-center pt-16 relative overflow-hidden">
  <div class="hero-gradient absolute inset-0 -z-10"></div>
  <div class="max-w-3xl mx-auto px-6 text-center">
    <p class="text-accent font-medium mb-4 animate-fade-in-up">
      Hi, my name is
    </p>
    <h1 class="text-5xl md:text-6xl font-bold mb-4 animate-fade-in-up">
      {hero.name}
    </h1>
    <p class="text-xl md:text-2xl text-gray-500 mb-8 animate-fade-in-up-delay">
      <span id="typed-tagline"></span><span id="cursor" class="text-accent">|</span>
    </p>

<script define:vars={{ tagline: hero.tagline }}>
  const el = document.getElementById("typed-tagline");
  const cursor = document.getElementById("cursor");
  let i = 0;
  const delay = 800; // wait for fade-in animation

  setTimeout(() => {
    const interval = setInterval(() => {
      el.textContent = tagline.slice(0, i + 1);
      i++;
      if (i >= tagline.length) {
        clearInterval(interval);
        // Blink cursor then hide
        setTimeout(() => cursor.style.display = "none", 2000);
      }
    }, 60);
  }, delay);
</script>
    <a
      href="#about"
      class="inline-block px-8 py-3 rounded-lg text-white bg-gradient-to-r from-accent to-blue-400 hover:from-accent-hover hover:to-blue-500 transition-all shadow-md hover:shadow-lg animate-fade-in-up-delay"
    >
      Learn more
    </a>
    <div class="flex justify-center gap-5 mt-8 animate-fade-in-up-delay">
      {social.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.name}
          class="text-gray-400 hover:text-accent transition-colors"
          set:html={socialIcons[s.icon]}
        />
      ))}
    </div>
  </div>
</section>
