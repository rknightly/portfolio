---
import { featuredProjects } from "../data";
import ProjectCard from "./ProjectCard.astro";
---

<section id="projects" class="py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 reveal">Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {featuredProjects.map((project) => (
        <div class="reveal">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
    <div class="text-center mt-10 reveal">
      <a
        href="/projects"
        class="border-2 border-accent text-accent px-6 py-2 rounded-lg hover:bg-accent hover:text-white transition-colors text-sm font-medium"
      >
        View all projects
      </a>
    </div>
  </div>
</section>
